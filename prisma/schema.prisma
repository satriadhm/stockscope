// Stockscope Database Schema
// Version controlled with Prisma migrations
// Last updated: 2026-03-30

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// =============================================================================
// USER MANAGEMENT (Current schema from NextAuth)
// =============================================================================

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  plan          String    @default("free")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  accounts      Account[]
  sessions      Session[]
  
  @@map("users")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime
  
  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =============================================================================
// USER-OWNED DATA (Sprint 2)
// =============================================================================

model Watchlist {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  name        String
  description String?
  color       String?  // Hex color for UI categorization
  position    Int      @default(0) // For drag-drop ordering
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  items       WatchlistItem[]
  
  @@index([userId])
  @@index([userId, position])
  @@map("watchlists")
}

model WatchlistItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  watchlistId String   @db.ObjectId
  ticker      String   // Stock ticker (e.g., "BBCA")
  addedAt     DateTime @default(now())
  position    Int      @default(0) // For drag-drop ordering within watchlist
  notes       String?  // Optional user notes
  
  watchlist   Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  
  @@unique([watchlistId, ticker]) // Prevent duplicate stocks in same watchlist
  @@index([watchlistId, position])
  @@map("watchlist_items")
}

// =============================================================================
// SAVED SCREENERS (Sprint 2)
// =============================================================================

model SavedScreener {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  name        String
  description String?
  filters     Json     // { sector, aiTier, govTier, minScore, maxScore, sortBy, sortOrder, searchQuery }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
  @@index([userId, createdAt])
  @@map("saved_screeners")
}

// =============================================================================
// PRICE ALERTS (Sprint 2)
// =============================================================================

model PriceAlert {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  ticker      String   // Stock ticker symbol
  condition   String   // "above" | "below"
  targetPrice Float
  isActive    Boolean  @default(true)
  triggeredAt DateTime?
  lastCheckedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
  @@index([isActive])
  @@index([ticker, isActive])
  @@map("price_alerts")
}

// =============================================================================
// USER PREFERENCES (Sprint 2)
// =============================================================================

model UserPreferences {
  id                  String  @id @default(auto()) @map("_id") @db.ObjectId
  userId              String  @unique @db.ObjectId
  language            String  @default("en") // "en" | "id"
  theme               String  @default("dark") // "light" | "dark" | "system"
  defaultView         String  @default("table") // "table" | "cards"
  emailNotifications  Boolean @default(true)
  pushNotifications   Boolean @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  @@map("user_preferences")
}
