# Set variables in the Vercel project (Settings → Environment Variables) and use .env.local for local dev.
# Never commit real secrets.

# MongoDB (required) — Atlas URI or mongodb://user:pass@host:27017/dbname
MONGODB_URI=
# NextAuth — use your public site URL in production (https://yourdomain.com)
NEXTAUTH_URL=
NEXTAUTH_SECRET=

# Google OAuth — Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Midtrans Snap
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=

# Optional — if your app reads a public API base URL
# NEXT_PUBLIC_API_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────────
# Stock Screener (AI-powered analysis)
# ──────────────────────────────────────────────────────────────────

# Anthropic API key for Claude AI analysis
# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-api-key

# News API key for sentiment analysis (optional)
# Get your key from https://newsapi.org
NEWS_API_KEY=your-news-api-key
