# Database
MONGODB_URI=

# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public API & App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_TOUR_COMPLETE_KEY=stockscope_tour_completed

# Midtrans Payment Gateway
MIDTRANS_SERVER_KEY=
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=

# Stripe (required for pricing page checkout)
# Get your publishable key from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# AI Integration
ANTHROPIC_API_KEY=

# Admin & Cron
# Comma-separated allowlist of admin emails (fail-closed: empty = no admins)
ADMIN_EMAILS=
# Shared secret for cron/internal endpoints (fail-closed: required to enable them)
CRON_SECRET=

# Development Overrides
PREMIUM_DEV_OVERRIDE=false
